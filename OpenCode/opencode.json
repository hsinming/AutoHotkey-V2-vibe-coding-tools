{
  "$schema": "https://opencode.ai/config.json",  
  "agent": {
    "ahk-orchestrator": {
      "description": "Master workflow controller for the AHK v2 coding agent ecosystem. Routes AHK v2 development requests to the appropriate specialist subagent after validation, context extraction, and delegation payload construction. Switch to this agent to start any AHK v2 task.",
      "mode": "primary",
      "color": "primary",
      "permission": {
        "task":      { "*": "deny", "ahk-*": "allow" },
        "read":      { "*": "allow" },
        "glob":      { "*": "allow" },
        "grep":      { "*": "allow" },
        "lsp":       "allow",
        "skill":     { "*": "allow" },
        "todowrite": "allow",
        "todoread":  "allow",
        "edit":      { "*.ahk": "allow", "*.md": "allow", "*.json": "allow", "*.js": "allow", "*.html": "allow", "*.css": "allow", "*.ini": "allow", "*.ps1": "allow", "*": "deny" },
        "write":     { "*.ahk": "allow", "*.md": "allow", "*.json": "allow", "*.js": "allow", "*.html": "allow", "*.css": "allow", "*.ini": "allow", "*.ps1": "allow", "*": "deny" },
        "bash": {
          "powershell*":           "deny",
          "pwsh*":                 "deny",
          "python*":               "deny",
          "py*":                   "deny",
          "git log *":             "allow",
          "git diff *":            "allow",
          "git status":            "allow",
          "npx ctx7@latest *":     "allow",
          "*":                     "deny"
        }
      }
    },
    "ahk-architect": {
      "description": "Software design authority for AHK v2. Produces complete architectural blueprints that ahk-code can implement without ambiguity. Invoke when a task requires evaluating class structure, data strategy, layer separation, or any design decision specific to this system.",
      "mode": "subagent",
      "hidden": true,
      "color": "#6B8AFF",
      "permission": {
        "read":     { "*": "allow" },
        "glob":     { "*": "allow" },
        "grep":     { "*": "allow" },
        "lsp":      "allow",
        "skill":    { "*": "allow" },
        "todoread": "allow",
        "webfetch": "allow",
        "edit":     { "*.md": "allow", "*.json": "allow", "*": "deny" },
        "write":    { "*.md": "allow", "*.json": "allow", "*": "deny" },
        "bash": {
          "powershell*":           "deny",
          "pwsh*":                 "deny",
          "python*":               "deny",
          "py*":                   "deny",
          "git log *":             "allow",
          "git diff *":            "allow",
          "npx ctx7@latest *":     "allow",
          "*":                     "deny"
        }
      }
    },
    "ahk-code": {
      "description": "AHK v2 implementation engine. Ingests a blueprint from ahk-architect or a delegation payload from ahk-orchestrator and produces production-grade, executable AHK v2 code. Only invoked after architectural review is complete.",
      "mode": "subagent",
      "hidden": true,
      "color": "#4CAF50",
      "permission": {
        "read":  { "*": "allow" },
        "glob":  { "*": "allow" },
        "grep":  { "*": "allow" },
        "edit":  { "*.ahk": "allow", "*": "deny" },
        "write": { "*.ahk": "allow", "*": "deny" },
        "lsp":      "allow",
        "skill":    { "*": "allow" },
        "todoread": "allow",
        "bash": {
          "powershell*":         "allow",
          "pwsh*":               "allow",
          "python*":             "allow",
          "py*":                 "allow",
          "autohotkey.exe /validate *":          "allow",
          "autohotkey.exe /errorstdout *":       "allow",
          "New-Object System.Diagnostics.ProcessStartInfo": "allow",          
          "git status":          "allow",
          "git diff *":          "allow",
          "git log *":           "allow",
          "git add *":           "allow",
          "git commit *":        "ask",
          "npx ctx7@latest *":   "allow",
          "*":                   "deny"
        }
      }
    },
    "ahk-debug": {
      "description": "AHK v2 code auditor. Analyzes submitted AHK v2 code or error traces, produces a structured diagnostic report categorized by severity, and outputs corrected code verified clean. Invoke when code is broken, throws errors, or exhibits unexpected runtime behavior.",
      "mode": "subagent",
      "hidden": true,
      "color": "#FF6B6B",
      "permission": {
        "read":  { "*": "allow" },
        "glob":  { "*": "allow" },
        "grep":  { "*": "allow" },
        "edit":  { "*.ahk": "allow", "*": "deny" },
        "write": { "*.ahk": "allow", "*": "deny" },
        "lsp":      "allow",
        "skill":    { "*": "allow" },
        "todoread": "allow",
        "bash": {
          "powershell*":                         "allow",
          "pwsh*":                               "allow",
          "python*":                             "allow",
          "py*":                                 "allow",
          "autohotkey.exe /validate *":          "allow",
          "autohotkey.exe /errorstdout *":       "allow",
          "New-Object System.Diagnostics.ProcessStartInfo": "allow",          
          "git status":                          "allow",
          "git diff *":                          "allow",
          "git log *":                           "allow",
          "npx ctx7@latest *":                   "allow",
          "*":                                   "deny"
        }
      }
    },
    "ahk-ask": {
      "description": "AHK v2 technical mentor. Answers questions about AHK v2 concepts, syntax, debugging patterns, and general programming topics. Can be @mentioned directly for quick questions; also invoked by ahk-orchestrator for conceptual queries.",
      "mode": "subagent",
      "color": "#FFB347",
      "permission": {
        "read":     { "*": "allow" },
        "glob":     { "*": "allow" },
        "grep":     { "*": "allow" },
        "lsp":      "allow",
        "skill":    { "*": "allow" },
        "todoread": "allow",
        "webfetch": "allow",
        "bash": {
          "powershell*":         "deny",
          "pwsh*":               "deny",
          "python*":             "deny",
          "py*":                 "deny",
          "npx ctx7@latest *":   "allow",
          "*":                   "deny"
        }
      }
    }
  }
}
